# ─── Project Identity ─────────────────────────────────────────────────────────
# Tên project — dùng để đặt tên container và network
PROJECT_NAME=workspace

# ─── Graphiti Memory ──────────────────────────────────────────────────────────
# group_id phân vùng memory trong Neo4j.
# Shared project memory: dùng tên project (vd: workspace, my-app)
# Personal memory:       dùng tên mình (vd: workspace-thang)
GRAPHITI_GROUP_ID=workspace

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Chọn provider và model cho LLM + Embedder
# LLM_PROVIDER và EMBEDDER_PROVIDER phải khớp với provider đã có API key bên dưới.
# Options: openai | anthropic | gemini | azure_openai | groq
LLM_PROVIDER=gemini
MODEL_NAME=gemini-2.0-flash
LLM_MAX_TOKENS=4096

EMBEDDER_PROVIDER=gemini
EMBEDDER_MODEL=gemini-embedding-2
EMBEDDER_DIMENSIONS=3072

# ─── API Keys ─────────────────────────────────────────────────────────────────
# Chỉ điền key của provider bạn đang dùng, bỏ qua các provider còn lại.

# Google Gemini
GOOGLE_API_KEY=your-google-api-key
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_LOCATION=us-central1

# OpenAI
# OPENAI_API_KEY=sk-proj-...
# OPENAI_API_URL=https://api.openai.com/v1

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=<deployment-name>
# AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=<embeddings-deployment-name>
# AZURE_OPENAI_API_VERSION=2024-10-21
# USE_AZURE_AD=false

# Groq
# GROQ_API_KEY=...

# Voyage (embeddings only)
# VOYAGE_API_KEY=...

# ─── Neo4j Database ───────────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-please
NEO4J_DATABASE=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Tuning bộ nhớ Neo4j (tùy theo RAM của máy)
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE=512m

# ─── Neo4j Connection URI (override nếu dùng Neo4j bên ngoài Docker) ─────────
# Trong Docker: bolt://neo4j:7687 (service name làm hostname)
# Ngoài Docker / remote: bolt://<host>:7687
NEO4J_URI=bolt://neo4j:7687

# ─── Graphiti MCP Server ──────────────────────────────────────────────────────
PORT_MCP=8001
SEMAPHORE_LIMIT=10
USE_PARALLEL_RUNTIME=false

# ─── Network Binding ──────────────────────────────────────────────────────────
# 127.0.0.1 = chỉ truy cập từ máy local (an toàn hơn, default)
# 0.0.0.0   = mở ra toàn bộ interfaces (dùng cho team server / remote access)
HOST_BIND=0.0.0.0

# ─── Shared Server (dành cho team dùng server chung) ─────────────────────────
# Nếu team có server dùng chung, đặt HOST_BIND=0.0.0.0 và thay URL trong .claude/settings.json:
# "url": "http://<server-ip>:8001/mcp"
