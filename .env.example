# =============================================================================
# WORKSPACE — Environment Configuration Template
# =============================================================================
# Sao chép file này thành .env rồi điền giá trị thực:
#   cp .env.example .env
#
# Quy tắc:
#   - Không commit file .env vào git
#   - Thay mọi giá trị có dạng <placeholder> trước khi chạy
#   - Biến có dấu # ở đầu là optional — bỏ comment nếu cần dùng
# =============================================================================


# =============================================================================
# PROJECT IDENTITY
# =============================================================================
# Tên project — dùng làm prefix cho container name và Docker network name.
# Ví dụ: "my-app" → container "my-app-neo4j", network "my-app-network"
# Không dùng dấu cách hoặc ký tự đặc biệt.
PROJECT_NAME=workspace


# =============================================================================
# GRAPHITI MEMORY
# =============================================================================
# group_id phân vùng memory trong Neo4j knowledge graph.
# Các episode/entity thuộc cùng group_id sẽ được search cùng nhau.
#
# Chiến lược đặt tên:
#   Shared project memory:  dùng tên project  (vd: "my-app")
#   Personal memory:        dùng tên-bạn      (vd: "my-app-thang")
#
# Mỗi Claude Code session nên dùng group_id phù hợp với ngữ cảnh.
GRAPHITI_GROUP_ID=workspace


# =============================================================================
# LLM PROVIDER
# =============================================================================
# Provider xử lý entity extraction, summarization, và graph operations.
# Options: openai | anthropic | gemini | azure_openai | groq
#
# Lưu ý:
#   - groq cung cấp inference nhanh cho open-source models (Llama, Mixtral)
#   - groq KHÔNG có embedding API — phải dùng EMBEDDER_PROVIDER khác
#   - Đảm bảo API key tương ứng được điền ở section API Keys bên dưới
LLM_PROVIDER=gemini

# Model name tương ứng với LLM_PROVIDER đã chọn.
# Gemini:    gemini-2.0-flash | gemini-2.5-pro | gemini-2.5-flash
# OpenAI:    gpt-4o-mini | gpt-4o | gpt-4.1 | o4-mini
# Anthropic: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-8
# Groq:      llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
# Azure:     tên deployment (không phải model name)
MODEL_NAME=gemini-2.0-flash

# Số token tối đa cho mỗi LLM request.
# Tăng nếu gặp lỗi truncation với episode dài.
# Giảm để tiết kiệm chi phí với các model tính tiền per-token.
LLM_MAX_TOKENS=4096


# =============================================================================
# EMBEDDER PROVIDER
# =============================================================================
# Provider tạo vector embedding để tìm kiếm semantic trong knowledge graph.
# Options: openai | azure_openai | gemini | voyage
#
# Lưu ý quan trọng:
#   - groq KHÔNG hỗ trợ embedding — chọn provider khác
#   - anthropic KHÔNG hỗ trợ embedding — chọn provider khác
#   - Một khi đã có data trong Neo4j, KHÔNG đổi embedder
#     (dimension mismatch sẽ break toàn bộ semantic search)
#
# Khuyến nghị:
#   gemini-embedding-2 → 3072 dimensions, hiệu suất tốt, free tier hào phóng
#   text-embedding-3-large → 3072 dimensions, chất lượng cao
#   voyage-3 → 1024 dimensions, cost-effective cho production
EMBEDDER_PROVIDER=gemini

# Model embedding tương ứng.
# Gemini:  gemini-embedding-2 (default 3072 dims) | text-embedding-004 (768 dims)
# OpenAI:  text-embedding-3-large (3072 dims) | text-embedding-3-small (1536 dims)
# Voyage:  voyage-3 (1024 dims) | voyage-3-large (2048 dims)
# Azure:   tên deployment embedding model
EMBEDDER_MODEL=gemini-embedding-2

# Số dimensions của embedding model. Phải khớp chính xác với model.
# gemini-embedding-2:    3072
# text-embedding-3-large: 3072
# text-embedding-3-small: 1536
# text-embedding-004:     768
# voyage-3:               1024
EMBEDDER_DIMENSIONS=3072


# =============================================================================
# RERANKER (CROSS-ENCODER)
# =============================================================================
# Reranker chấm điểm lại kết quả search để cải thiện độ chính xác.
# Config hoàn toàn độc lập với LLM và Embedder.
#
# Options:
#   gemini   → GeminiRerankerClient: dùng Gemini API (cần GOOGLE_API_KEY)
#   openai   → OpenAIRerankerClient: dùng OpenAI logprobs (cần OPENAI_API_KEY)
#   bge      → BGERerankerClient: model local BAAI/bge-reranker-v2-m3
#              (~600MB download lần đầu, không cần API key, chạy trên CPU)
#   none     → Tắt reranking hoàn toàn, kết quả trả về theo thứ tự vector search
#   (để trống) → Auto-detect: gemini nếu có GOOGLE_API_KEY,
#                              openai nếu có OPENAI_API_KEY, else none
#
# Trade-offs:
#   gemini/openai → chất lượng tốt, có chi phí API call mỗi lần search
#   bge           → miễn phí, latency cao hơn (inference trên CPU trong container)
#   none          → nhanh nhất, chất lượng phụ thuộc hoàn toàn vào embedder
RERANKER_PROVIDER=gemini


# =============================================================================
# API KEYS
# =============================================================================
# Điền key của tất cả provider bạn dùng (LLM + Embedder + Reranker có thể khác nhau).
# Provider không dùng: để trống hoặc giữ nguyên comment.

# ── Google Gemini ──────────────────────────────────────────────────────────────
# Dùng cho: LLM_PROVIDER=gemini | EMBEDDER_PROVIDER=gemini | RERANKER_PROVIDER=gemini
# Lấy tại: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=<your-google-api-key>

# Google Cloud Project — chỉ cần nếu dùng Vertex AI (thường để trống với AI Studio)
# GOOGLE_PROJECT_ID=<your-gcp-project-id>

# Region cho Vertex AI (bỏ qua nếu dùng AI Studio key thông thường)
GOOGLE_LOCATION=us-central1

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Dùng cho: LLM_PROVIDER=openai | EMBEDDER_PROVIDER=openai | RERANKER_PROVIDER=openai
# Lấy tại: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...

# Chỉ điền nếu dùng OpenAI-compatible endpoint (Ollama, LM Studio, v.v.)
# OPENAI_API_URL=https://api.openai.com/v1

# ── Anthropic ──────────────────────────────────────────────────────────────────
# Dùng cho: LLM_PROVIDER=anthropic
# Lưu ý: Anthropic không có embedding API
# Lấy tại: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# ── Groq ───────────────────────────────────────────────────────────────────────
# Dùng cho: LLM_PROVIDER=groq (inference cực nhanh cho open-source models)
# Lưu ý: Groq không có embedding API — phải dùng EMBEDDER_PROVIDER khác
# Lấy tại: https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# ── Voyage AI ──────────────────────────────────────────────────────────────────
# Dùng cho: EMBEDDER_PROVIDER=voyage (embedding chất lượng cao, cost-effective)
# Lấy tại: https://dash.voyageai.com/api-keys
# VOYAGE_API_KEY=pa-...

# ── Azure OpenAI ───────────────────────────────────────────────────────────────
# Dùng cho: LLM_PROVIDER=azure_openai | EMBEDDER_PROVIDER=azure_openai
# Cần tạo deployment riêng cho LLM và embedding trong Azure Portal
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=<llm-deployment-name>
# AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=<embeddings-deployment-name>
# AZURE_OPENAI_API_VERSION=2024-10-21
# USE_AZURE_AD=false


# =============================================================================
# NEO4J DATABASE
# =============================================================================
# Credentials truy cập Neo4j — dùng cho cả Docker container và Graphiti client.

# Username mặc định của Neo4j (thường không cần đổi).
NEO4J_USER=neo4j

# ⚠ BẮT BUỘC ĐỔI — không để giá trị mặc định trong production.
# Ít nhất 8 ký tự, kết hợp chữ hoa/thường/số/ký tự đặc biệt.
NEO4J_PASSWORD=<change-me-strong-password>

# Tên database trong Neo4j. Mặc định "neo4j" (database system mặc định).
# Có thể dùng tên khác nếu muốn phân tách data (Neo4j Enterprise feature).
NEO4J_DATABASE=neo4j

# Port expose ra host machine.
# Đổi nếu bị conflict với service khác trên máy.
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Connection URI mà Graphiti dùng để kết nối Neo4j.
# Trong Docker:   bolt://neo4j:7687  ← dùng service name làm hostname (KHÔNG đổi)
# Remote/bên ngoài Docker: bolt://<host>:7687
NEO4J_URI=bolt://neo4j:7687

# ── Memory Tuning ──────────────────────────────────────────────────────────────
# Điều chỉnh theo RAM của máy để tránh OOM hoặc lãng phí tài nguyên.
#
# Gợi ý:
#   RAM 8GB:  HEAP_INITIAL=512m, HEAP_MAX=1G,  PAGECACHE=1G
#   RAM 16GB: HEAP_INITIAL=1G,   HEAP_MAX=2G,  PAGECACHE=2G
#   RAM 32GB: HEAP_INITIAL=2G,   HEAP_MAX=4G,  PAGECACHE=4G
#
# HEAP:      JVM heap cho query processing. Tăng nếu gặp GC overhead.
# PAGECACHE: Cache data từ disk vào RAM. Lớn hơn = query nhanh hơn.
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE=512m


# =============================================================================
# GRAPHITI MCP SERVER
# =============================================================================
# Port expose MCP server ra host machine.
# Đổi nếu port 8001 bị conflict.
PORT_MCP=8001

# Số request LLM/Embedder xử lý đồng thời tối đa.
# Tránh rate limit của API provider.
# Gợi ý theo provider:
#   Gemini free tier:    5
#   Gemini paid:        20
#   OpenAI tier 1:      10
#   OpenAI tier 3+:     30
#   Groq free:           5
#   Groq paid:          30
SEMAPHORE_LIMIT=10

# Bật Neo4j parallel runtime cho query phức tạp.
# Chỉ có tác dụng với Neo4j Enterprise. Để false với Community edition.
USE_PARALLEL_RUNTIME=false


# =============================================================================
# NETWORK BINDING
# =============================================================================
# Interface mà các port được bind vào.
#
#   127.0.0.1 → chỉ truy cập từ localhost (an toàn, dùng cho local dev)
#   0.0.0.0   → mở ra tất cả network interface (dùng khi muốn team truy cập)
#
# ⚠ Khi dùng 0.0.0.0, đảm bảo firewall server đã được cấu hình đúng.
HOST_BIND=0.0.0.0
